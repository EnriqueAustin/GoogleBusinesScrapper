// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id            Int      @id @default(autoincrement())
  name          String
  category      String?
  address       String?
  city          String?
  phone         String?
  website       String?
  hasWebsite    Boolean  @default(false)
  rating        Float?
  reviewCount   Int?
  socials       String?
  emails        String?
  websiteStatus String?
  techStack     String?
  seoStatus     String?
  leadScore     Int      @default(0)
  notes         String?
  tags          String?
  customFields  Json?
  query         String?
  scrapedAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // CRM Sales Pipeline Fields
  crmStatus          String   @default("new")     // new | attempting | connected | qualified | disqualified | closed_won | closed_lost
  callCount          Int      @default(0)
  lastCalledAt       DateTime?
  nextFollowUp       DateTime?
  qualificationNotes String?
  estimatedValue     Float?
  websitePainPoints  String?

  // Relations
  logs          LeadLog[]
  calls         CallLog[]

  @@unique([name, address])
  @@index([hasWebsite])
  @@index([query])
  @@index([category])
  @@index([rating])
  @@index([leadScore])
  @@index([city])
  @@index([crmStatus])
  @@index([nextFollowUp])
}

model LeadLog {
  id        Int      @id @default(autoincrement())
  leadId    Int
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  action    String
  field     String?
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())

  @@index([leadId])
}

model CallLog {
  id        Int      @id @default(autoincrement())
  leadId    Int
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      String   @default("call") // call, email, note
  outcome   String   // answered | voicemail | no_answer | callback | interested | not_interested | left_message
  notes     String?
  duration  Int?     // seconds
  createdAt DateTime @default(now())

  @@index([leadId])
}

model Query {
  id        String   @id @default(uuid())
  query     String   @unique
  scrapedAt DateTime @default(now())
}

model Job {
  id           String    @id @default(uuid())
  query        String
  status       String    @default("waiting")
  resultsCount Int       @default(0)
  durationMs   Int?
  params       String?
  createdAt    DateTime  @default(now())
  startedAt    DateTime?
  completedAt  DateTime?
}

model Setting {
  key   String @id
  value String
}
